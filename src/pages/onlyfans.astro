---
import Container from "~/components/common/container.astro";
import Link from "~/components/common/link.astro";
import Layout from "~/layouts/Layout.astro";

export const prerender = false;

const ip = Astro.clientAddress;
---

<Layout
  content={{
    title: "onlyfans | advtszn",
    description: "subscribe to my onlyfans channel xoxo!",
  }}
>
  <main>
    <Container>
      <div class="space-y-2.5 lg:max-w-[50%]">
        <h1 class="font-serif text-4xl md:text-6xl">
          ffs there's no onlyfans here
        </h1>

        <p
          class="text-muted-foreground font-serif text-2xl leading-[150%] md:text-4xl "
        >
          but i got your ip address nevertheless
        </p>
        <p class="text-2xl md:text-4xl">{ip}</p>
        <p class="text-lg text-muted-foreground font-medium">
          do check out rest of my <Link href="/">portfolio</Link> though!
        </p>
      </div>
    </Container>
  </main>
</Layout>
